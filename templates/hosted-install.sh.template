#!/usr/bin/env bash
# Hosted entry template for OpenClaw installer
# 1) Put this file on your CDN/domain as install.sh
# 2) Optional: override OPENCLAW_RAW_INSTALL_URL if you forked this repo

set -euo pipefail

RAW_URL="${OPENCLAW_RAW_INSTALL_URL:-https://raw.githubusercontent.com/ShylockJEe/Openclaw_tool/main/bootstrap.sh}"
TMP_FILE="$(mktemp /tmp/openclaw-install-XXXXXX.sh)"
trap 'rm -f "$TMP_FILE"' EXIT

curl -fsSL "$RAW_URL" -o "$TMP_FILE"
chmod +x "$TMP_FILE"

exec bash "$TMP_FILE" "$@"
